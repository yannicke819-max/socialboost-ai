# =========================================================================
# SOCIALBOOST AI — Variables d'environnement
#
# Règle absolue : tout ce qui n'est PAS préfixé `NEXT_PUBLIC_` reste sur le
# serveur. Les clés `NEXT_PUBLIC_*` se retrouvent dans le bundle navigateur
# — n'y mettre que des valeurs publiques.
# =========================================================================

# --- Application ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- IA (server-only) ----------------------------------------------------
ANTHROPIC_API_KEY=

# --- Supabase ------------------------------------------------------------
# URL et anon key sont publiques (utilisées côté browser avec RLS active).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role bypasse RLS — JAMAIS exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe --------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs (server-only pour éviter le tampering côté client)
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_CREATOR_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=

# --- OAuth providers (client_id public OK, secret server-only) ----------
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/oauth/linkedin/callback

NEXT_PUBLIC_INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/oauth/instagram/callback

NEXT_PUBLIC_X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/oauth/x/callback

# --- Inngest (jobs scheduling) ------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Observabilité -------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
